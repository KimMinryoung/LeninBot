# leninbot environment template
#
# Copy to .env for local development:
#   cp .env.example .env
# Then fill in each value.
#
# In production, Tier A (secrets) live in /etc/credstore.encrypted/ and are
# loaded via systemd LoadCredentialEncrypted — they do NOT need to be in .env
# for services managed by systemd. .env is for the dev loop only.
#
# See scripts/migrate_secrets_to_credstore.py for the migration flow.
# See secrets_loader.py for the credstore→.env fallback resolution order.

# ════════════════════════════════════════════════════════════════════════════
# Tier A — SECRETS (production: systemd credentials, dev: .env)
# ════════════════════════════════════════════════════════════════════════════

# LLM providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
ALIBABA_API_KEY=
HF_TOKEN=

# Web tooling
TAVILY_API_KEY=
REPLICATE_API_TOKEN=
RESEND_API_KEY=

# Leninbot-internal
ADMIN_API_KEY=
AI_DIARY_API_KEY=

# External platforms
GITHUB_TOKEN=
MOLTBOOK_API_KEY=
GRAFFITI_API_KEY=
TELEGRAM_BOT_TOKEN=

# Infra
DB_PASSWORD=
NEO4J_PASSWORD=
EMAIL_IMAP_PASSWORD=
EMAIL_SMTP_PASSWORD=
R2_CF_API_TOKEN=

# ════════════════════════════════════════════════════════════════════════════
# Tier B — non-secret config (safe to leave in .env in all environments)
# ════════════════════════════════════════════════════════════════════════════

# Bot identity / access control
ALLOWED_USER_IDS=
TELEGRAM_CHAT_ID=
MY_DOMAIN=
RAZVEDCHIK_TELEGRAM_NOTIFY=0
TELEGRAM_BROADCAST_MOLTBOOK_ENABLED=true
TELEGRAM_BROADCAST_DIARY_ENABLED=false
TELEGRAM_BROADCAST_AUTONOMOUS_PROJECT_IDS=2

# Postgres
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_POOL_MODE=transaction
DB_SSL=require
VECTOR_DB_TABLE_NAME=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_DATABASE=neo4j

# Redis
REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 (public-ish identifiers)
R2_CF_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Email bridge
EMAIL_BRIDGE_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_FROM_EMAIL=
EMAIL_SMTP_FROM_NAME=Cyber-Lenin
EMAIL_POLL_INTERVAL_SECONDS=120
EMAIL_DEFAULT_APPROVER_USER_ID=

# Local/remote LLM endpoints (self-hosted)
DEEPSEEK_BASE_URL=https://api.deepseek.com
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
MOON_LLM_BASE_URL=
MOON_LLM_MODEL=

# External / misc
AI_DIARY_API_URL=
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
FRONTEND_DIR=

# Wallet public addresses (not secrets — private keys live in credstore)
WALLET_ETH_ADDRESS=
WALLET_SOL_ADDRESS=
WALLET_TRX_ADDRESS=

# ════════════════════════════════════════════════════════════════════════════
# Tier C (deploy state / paths) — intentionally removed
# ════════════════════════════════════════════════════════════════════════════
# PROJECT_ROOT, VENV_PYTHON, VENV_PIP, GIT_BRANCH, DEPLOY_LOCK/LOG/META
# are now derived in code (Path(__file__)...). Do not re-add them to .env.
