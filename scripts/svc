#!/usr/bin/env bash
# svc — LeninBot unified service management
#
# Usage:
#   svc deploy [--api|--telegram|--frontend|--all] [--restart]
#       Pull code, install deps if changed, restart services, notify via Telegram.
#       Called by Telegram /deploy command. Default: --all
#
#   svc boot
#       Start all services in dependency order with health checks. For server reboot.
#
#   svc kill <service...>
#       Force-stop immediately (SIGKILL). For stopping runaway jobs.
#
#   svc restart <service...>
#       Force-kill then start. For stopping runaway jobs and restarting.
#
#   svc status
#       Show status of all services and timers.
#
# Services: neo4j embedding llama api telegram browser frontend
# Timers:   diary experience razvedchik
# Special:  all

set -euo pipefail

# Resolve DEPLOY_DIR from script location (scripts/ lives inside it)
DEPLOY_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load .env
if [[ -f "$DEPLOY_DIR/.env" ]]; then
    set -a
    source "$DEPLOY_DIR/.env"
    set +a
fi

# Defaults (overridden by .env if set)
FRONTEND_DIR="${FRONTEND_DIR:-$DEPLOY_DIR/../frontend}"
BRANCH="${GIT_BRANCH:-main}"
VENV="$DEPLOY_DIR/venv"
LOG="${DEPLOY_LOG:-/tmp/leninbot-deploy.log}"
DEPLOY_META="${DEPLOY_META:-/tmp/leninbot-deploy-meta.json}"
LOCK_FILE="${DEPLOY_LOCK:-/tmp/leninbot-deploy.lock}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Ordered by dependency
ALL_SERVICES=(neo4j embedding llama api telegram browser frontend)
ALL_TIMERS=(diary experience razvedchik)

log()  { echo -e "${GREEN}[svc]${NC} $*"; }
warn() { echo -e "${YELLOW}[svc]${NC} $*"; }
err()  { echo -e "${RED}[svc]${NC} $*" >&2; }

# ── systemctl wrapper (handles root vs sudo) ─────────────────────
_run_systemctl() {
    if [ "$(id -u)" -eq 0 ]; then
        /usr/bin/systemctl "$@"
    else
        sudo /usr/bin/systemctl "$@"
    fi
}

# ── Unit name mapping ────────────────────────────────────────────
to_unit() {
    local name="$1"
    case "$name" in
        frontend) echo "docker:leninbot-frontend" ;;
        diary|experience|razvedchik) echo "leninbot-${name}.timer" ;;
        *) echo "leninbot-${name}.service" ;;
    esac
}

resolve_names() {
    local -a result=()
    for name in "$@"; do
        if [[ "$name" == "all" ]]; then
            result+=("${ALL_SERVICES[@]}" "${ALL_TIMERS[@]}")
        else
            result+=("$name")
        fi
    done
    echo "${result[@]}"
}

# ── Service primitives ───────────────────────────────────────────
do_start() {
    local name="$1"
    local unit
    unit=$(to_unit "$name")
    if [[ "$unit" == docker:* ]]; then
        local container="${unit#docker:}"
        if docker ps --format '{{.Names}}' | grep -qx "$container"; then
            log "$name: already running"
        else
            log "$name: starting container..."
            docker start "$container"
        fi
    else
        log "$name: starting $unit..."
        _run_systemctl start "$unit"
    fi
}

do_stop() {
    local name="$1" force="${2:-no}"
    local unit
    unit=$(to_unit "$name")
    if [[ "$unit" == docker:* ]]; then
        local container="${unit#docker:}"
        if [[ "$force" == "yes" ]]; then
            log "$name: killing container..."
            docker kill "$container" 2>/dev/null || true
        else
            log "$name: stopping container..."
            docker stop "$container" 2>/dev/null || true
        fi
    else
        if [[ "$force" == "yes" ]]; then
            log "$name: killing $unit..."
            _run_systemctl kill -s SIGKILL "$unit" 2>/dev/null || true
        else
            log "$name: stopping $unit..."
            _run_systemctl stop "$unit" 2>/dev/null || true
        fi
    fi
}

do_graceful_restart() {
    local name="$1"
    local unit
    unit=$(to_unit "$name")
    if [[ "$unit" == docker:* ]]; then
        local container="${unit#docker:}"
        log "$name: restarting container..."
        docker restart "$container"
    else
        log "$name: restarting $unit..."
        _run_systemctl restart "$unit"
    fi
}

wait_healthy() {
    local name="$1" check="$2" max_wait="${3:-30}"
    local elapsed=0
    while (( elapsed < max_wait )); do
        if eval "$check" &>/dev/null; then
            log "$name: healthy"
            return 0
        fi
        sleep 2
        elapsed=$((elapsed + 2))
    done
    warn "$name: not healthy after ${max_wait}s (continuing anyway)"
    return 1
}

# ── Telegram notification ────────────────────────────────────────
_notify_telegram() {
    local msg="$1"
    source "$DEPLOY_DIR/.env" 2>/dev/null || true
    if [[ -n "${TELEGRAM_BOT_TOKEN:-}" && -n "${ALLOWED_USER_IDS:-}" ]]; then
        # Single-owner: send to first (only) ID, no broadcast
        local uid
        uid=$(echo "$ALLOWED_USER_IDS" | cut -d',' -f1 | tr -d ' ')
        if [[ -n "$uid" ]]; then
            curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
                -d chat_id="$uid" -d text="$msg" -d parse_mode="Markdown" > /dev/null 2>&1 || true
        fi
    fi
}

# ── Git fetch with retry ────────────────────────────────────────
_git_fetch_with_retry() {
    local max_attempts=4 attempt=1
    while (( attempt <= max_attempts )); do
        if git fetch --prune origin; then
            return 0
        fi
        warn "git fetch failed (attempt $attempt/$max_attempts) — retrying"
        git remote prune origin || true
        git gc --prune=now --quiet || true
        sleep $((attempt * 2))
        attempt=$((attempt + 1))
    done
    return 1
}

# ── Frontend docker build + deploy ───────────────────────────────
_deploy_frontend() {
    local force_restart="${1:-0}"
    cd "$FRONTEND_DIR"

    git fetch origin
    local LOCAL_FE REMOTE_FE
    LOCAL_FE=$(git rev-parse HEAD)
    REMOTE_FE=$(git rev-parse origin/master)

    if [[ "$LOCAL_FE" == "$REMOTE_FE" && "$force_restart" -eq 0 ]]; then
        log "frontend: no changes → skip"
        cd "$DEPLOY_DIR"
        return 0
    fi

    git pull origin master
    docker build -t leninbot-frontend .

    docker stop leninbot-frontend 2>/dev/null || true
    docker rm leninbot-frontend 2>/dev/null || true

    # --network leninbot_default gives the container:
    #   (a) hostname DNS to leninbot-redis / leninbot-neo4j (user-defined
    #       networks have Docker's embedded DNS; the default bridge does not)
    #   (b) a 172.18.x source IP which the host's ufw rule allows to reach
    #       the :8000 backend (rule is 172.16.0.0/12, covering all Docker
    #       private subnets)
    docker run -d \
        --name leninbot-frontend \
        --network leninbot_default \
        --add-host=host.docker.internal:host-gateway \
        -p 127.0.0.1:3000:3000 \
        --restart unless-stopped \
        --env-file "$FRONTEND_DIR/.env" \
        -v "$FRONTEND_DIR/data:/app/data" \
        leninbot-frontend

    docker image prune -f
    log "frontend: deployed"
    cd "$DEPLOY_DIR"
}

# ════════════════════════════════════════════════════════════════
# Commands
# ════════════════════════════════════════════════════════════════

cmd_deploy() {
    local FORCE_RESTART=0
    local SERVICE="all"

    for arg in "$@"; do
        case "$arg" in
            --restart|-r) FORCE_RESTART=1 ;;
            --telegram)   SERVICE="telegram" ;;
            --api)        SERVICE="api" ;;
            --frontend)   SERVICE="frontend" ;;
            --all)        SERVICE="all" ;;
            --help|-h)
                echo "Usage: svc deploy [--api|--telegram|--frontend|--all] [--restart]"
                echo "  --restart, -r   Restart even when no new commit is found."
                echo "  --telegram      Restart leninbot-telegram only."
                echo "  --api           Restart leninbot-api only."
                echo "  --frontend      Rebuild and restart frontend container only."
                echo "  --all           Restart all services (default)."
                exit 0
                ;;
            *)
                err "Unknown option: $arg"
                err "Usage: svc deploy [--api|--telegram|--frontend|--all] [--restart]"
                exit 2
                ;;
        esac
    done

    # Concurrency lock
    exec 9>"$LOCK_FILE"
    if ! flock -n 9; then
        warn "Another deploy is already running. Skipping."
        _notify_telegram "⚠️ *Deploy 스킵*: 이미 다른 deploy가 진행 중입니다."
        exit 0
    fi

    # Error trap — notify on failure
    _on_error() {
        local exit_code=$? failed_line=$1
        local error_context
        error_context=$(tail -5 "$LOG" 2>/dev/null | head -4)
        err "Deploy failed (line $failed_line, exit $exit_code)"
        _notify_telegram "❌ *Deploy 실패* (exit $exit_code)
단계: line $failed_line
\`\`\`
$error_context
\`\`\`"
        cat > "$DEPLOY_META" <<METAEOF
{
  "timestamp": "$(date -Iseconds)",
  "status": "failed",
  "exit_code": $exit_code,
  "failed_line": $failed_line,
  "error": $(echo "$error_context" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read().strip()))' 2>/dev/null || echo '""')
}
METAEOF
        exit $exit_code
    }
    trap '_on_error $LINENO' ERR
    set -eE

    # Tee output to log
    exec > >(tee "$LOG") 2>&1

    cd "$DEPLOY_DIR"
    log "=== Deploy start (target: $SERVICE) ==="

    local LOCAL="" REMOTE="" DID_PULL=0 CHANGES="" RESTARTED=""

    # ── Frontend-only mode: skip backend steps ──
    if [[ "$SERVICE" == "frontend" ]]; then
        CHANGES="(frontend-only deploy)"
    else
        # 1. Git pull
        _git_fetch_with_retry
        LOCAL=$(git rev-parse HEAD)
        REMOTE=$(git rev-parse "origin/$BRANCH")

        if [[ "$LOCAL" == "$REMOTE" ]]; then
            if [[ "$FORCE_RESTART" -eq 0 ]]; then
                log "Already up to date. Nothing to do."
                exit 0
            fi
            log "Already up to date, but --restart requested."
            CHANGES="(no code change: restart only)"
        else
            CHANGES=$(git log "$LOCAL..$REMOTE" --oneline)
            log "Changes detected: $LOCAL → $REMOTE"
            echo "$CHANGES"
            git pull origin "$BRANCH"
            DID_PULL=1
        fi

        # 2. Dependencies
        if [[ "$DID_PULL" -eq 1 ]] && git diff "$LOCAL" "$REMOTE" --name-only | grep -q "requirements"; then
            log "Requirements changed → pip install"
            source "$VENV/bin/activate"
            pip install -r requirements.txt --quiet
            if pip show playwright > /dev/null 2>&1; then
                log "Ensuring Playwright chromium..."
                playwright install --with-deps chromium 2>/dev/null || true
            fi
        else
            log "No dependency changes"
        fi

        # 3. Deploy metadata
        cat > "$DEPLOY_META" <<METAEOF
{
  "timestamp": "$(date -Iseconds)",
  "status": "success",
  "prev_commit": "$LOCAL",
  "new_commit": "$REMOTE",
  "changes": $(echo "$CHANGES" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read().strip()))'),
  "deps_updated": $(git diff "$LOCAL" "$REMOTE" --name-only | grep -q "requirements" && echo "true" || echo "false")
}
METAEOF

        # 4. daemon-reload if systemd units changed
        if [[ "$DID_PULL" -eq 1 ]] && git diff "$LOCAL" "$REMOTE" --name-only | grep -q "systemd/"; then
            log "systemd unit files changed → daemon-reload"
            _run_systemctl daemon-reload
        fi
    fi

    # 5. Restart services
    local SUMMARY
    SUMMARY=$(git log --oneline -1 2>/dev/null || echo "n/a")

    if [[ "$SERVICE" == "all" || "$SERVICE" == "api" ]]; then
        do_graceful_restart api
        RESTARTED="api"
    fi

    # 6. Notify BEFORE restarting telegram (since telegram restart kills the bot)
    _notify_telegram "✅ *Deploy 완료* [$SERVICE]
\`$SUMMARY\`
변경 커밋:
\`\`\`
$CHANGES
\`\`\`"

    # 7. Browser worker
    if [[ "$SERVICE" == "all" ]] && _run_systemctl is-active --quiet leninbot-browser 2>/dev/null; then
        do_graceful_restart browser
        RESTARTED="${RESTARTED:+$RESTARTED+}browser"
    fi

    # 8. Telegram last (restarts the bot process — may kill this script)
    if [[ "$SERVICE" == "all" || "$SERVICE" == "telegram" ]]; then
        do_graceful_restart telegram
        RESTARTED="${RESTARTED:+$RESTARTED+}telegram"
    fi

    # 9. Frontend
    if [[ "$SERVICE" == "all" || "$SERVICE" == "frontend" ]]; then
        if [[ -d "$FRONTEND_DIR" ]]; then
            _deploy_frontend "$FORCE_RESTART"
            RESTARTED="${RESTARTED:+$RESTARTED+}frontend"
        fi
    fi

    log "=== Deploy complete [$RESTARTED]: $SUMMARY ==="
}

cmd_boot() {
    log "=== LeninBot full boot sequence ==="
    _run_systemctl daemon-reload

    # 1. Infrastructure
    do_start neo4j
    wait_healthy neo4j "docker exec leninbot-neo4j wget -qO- http://localhost:7474" 60
    wait_healthy redis "docker exec leninbot-redis redis-cli ping" 30

    # 2. Embedding (needed by api and telegram)
    do_start embedding
    wait_healthy embedding "curl -sf http://localhost:8100/health" 60

    # 3. LLM fallback (independent)
    do_start llama

    # 4. API + Telegram (both depend on neo4j + embedding)
    do_start api
    do_start telegram
    wait_healthy api "curl -sf http://localhost:8000/docs" 15

    # 5. Browser worker (depends on telegram)
    do_start browser

    # 6. Frontend
    do_start frontend
    wait_healthy frontend "curl -sf http://localhost:3000" 15

    # 7. Timers
    for t in "${ALL_TIMERS[@]}"; do
        do_start "$t"
    done

    echo
    log "=== Boot complete ==="
    cmd_status
}

cmd_kill() {
    if [[ $# -eq 0 ]]; then
        err "Usage: svc kill <service...>"
        exit 1
    fi
    local names=($(resolve_names "$@"))
    local i
    for (( i=${#names[@]}-1; i>=0; i-- )); do
        do_stop "${names[$i]}" yes
    done
}

cmd_restart() {
    if [[ $# -eq 0 ]]; then
        err "Usage: svc restart <service...>"
        exit 1
    fi
    local names=($(resolve_names "$@"))

    # Kill in reverse order
    local i
    for (( i=${#names[@]}-1; i>=0; i-- )); do
        do_stop "${names[$i]}" yes
    done
    sleep 1

    # Start in forward order
    for name in "${names[@]}"; do
        do_start "$name"
    done
    echo
    cmd_status
}

cmd_status() {
    echo -e "${GREEN}=== Services ===${NC}"
    for name in "${ALL_SERVICES[@]}"; do
        local unit state
        unit=$(to_unit "$name")
        if [[ "$unit" == docker:* ]]; then
            local container="${unit#docker:}"
            state=$(docker inspect -f '{{.State.Status}}' "$container" 2>/dev/null || echo "not found")
            if [[ "$state" == "running" ]]; then
                echo -e "  ${GREEN}●${NC} $name ($container): $state"
            else
                echo -e "  ${RED}●${NC} $name ($container): $state"
            fi
        else
            state=$(_run_systemctl is-active "$unit" 2>/dev/null || true)
            if [[ "$state" == "active" || "$state" == "activating" ]]; then
                echo -e "  ${GREEN}●${NC} $name: $state"
            else
                echo -e "  ${RED}●${NC} $name: ${state:-dead}"
            fi
        fi
    done

    echo -e "\n${GREEN}=== Timers ===${NC}"
    for name in "${ALL_TIMERS[@]}"; do
        local unit state
        unit=$(to_unit "$name")
        state=$(_run_systemctl is-active "$unit" 2>/dev/null || true)
        if [[ "$state" == "active" ]]; then
            echo -e "  ${GREEN}●${NC} $name: $state"
        else
            echo -e "  ${RED}●${NC} $name: ${state:-dead}"
        fi
    done
}

# ════════════════════════════════════════════════════════════════
# Entry point
# ════════════════════════════════════════════════════════════════

case "${1:-}" in
    deploy)  shift; cmd_deploy "$@" ;;
    boot)    cmd_boot ;;
    kill)    shift; cmd_kill "$@" ;;
    restart) shift; cmd_restart "$@" ;;
    status)  cmd_status ;;
    *)
        cat <<'USAGE'
Usage: svc <command> [args...]

Commands:
  deploy [--api|--telegram|--frontend|--all] [--restart]
      Pull code, install deps, restart services, notify via Telegram.
      Default: --all. Use --restart to force restart even without changes.

  boot
      Start all services in dependency order with health checks.
      Use after server reboot.

  kill <service...>
      Force-stop immediately (SIGKILL). For runaway jobs.

  restart <service...>
      Force-kill then start. For runaway jobs that need restarting.

  status
      Show status of all services and timers.

Services: neo4j embedding llama api telegram browser frontend
Timers:   diary experience razvedchik
Special:  all
USAGE
        exit 1
        ;;
esac
