[Unit]
Description=Translate untranslated LeninBot research documents into English
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=grass
WorkingDirectory=/home/grass/leninbot
EnvironmentFile=/home/grass/leninbot/.env
LoadCredentialEncrypted=deepseek_api_key:/etc/credstore.encrypted/deepseek_api_key.cred
LoadCredentialEncrypted=db_password:/etc/credstore.encrypted/db_password.cred
ExecStart=/home/grass/leninbot/venv/bin/python /home/grass/leninbot/scripts/translate_research_documents.py --limit 2 --max-chars 60000
