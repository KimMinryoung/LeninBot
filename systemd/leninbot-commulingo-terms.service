[Unit]
Description=LeninBot CommuLingo glossary-term curator
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=grass
WorkingDirectory=/home/grass/leninbot
EnvironmentFile=/home/grass/leninbot/.env
Environment=PYTHONUNBUFFERED=1
LoadCredentialEncrypted=deepseek_api_key:/etc/credstore.encrypted/deepseek_api_key.cred
LoadCredentialEncrypted=db_password:/etc/credstore.encrypted/db_password.cred
LoadCredentialEncrypted=tavily_api_key:/etc/credstore.encrypted/tavily_api_key.cred
ExecStart=/home/grass/leninbot/venv/bin/python /home/grass/leninbot/scripts/commulingo_terms_maintainer.py
TimeoutStartSec=900
StandardOutput=journal
StandardError=journal
