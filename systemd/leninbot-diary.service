[Unit]
Description=LeninBot Diary Writer (one-shot)
After=network.target

[Service]
Type=oneshot
User=grass
WorkingDirectory=/home/grass/leninbot
EnvironmentFile=/home/grass/leninbot/.env
ExecStart=/home/grass/leninbot/venv/bin/python -c "from diary_writer import write_diary; write_diary()"
TimeoutStartSec=300
