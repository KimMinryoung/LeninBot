[Unit]
Description=LeninBot Experience Writer (one-shot)
After=network.target

[Service]
Type=oneshot
User=grass
WorkingDirectory=/home/grass/leninbot
EnvironmentFile=/home/grass/leninbot/.env
ExecStart=/home/grass/leninbot/venv/bin/python -c "from experience_writer import write_experiences; write_experiences()"
TimeoutStartSec=300
