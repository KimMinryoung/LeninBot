[Unit]
Description=LeninBot Neo4j (Docker Compose)
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/grass/leninbot
ExecStart=/usr/bin/docker compose -f docker-compose.neo4j.yml up -d
ExecStop=/usr/bin/docker compose -f docker-compose.neo4j.yml down
EnvironmentFile=/home/grass/leninbot/.env

[Install]
WantedBy=multi-user.target
