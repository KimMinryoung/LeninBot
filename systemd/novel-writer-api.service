[Unit]
Description=Novel Writer API (FastAPI + Uvicorn)
After=network.target

[Service]
User=grass
WorkingDirectory=/home/grass/leninbot
EnvironmentFile=/home/grass/leninbot/.env
ExecStart=/home/grass/leninbot/venv/bin/python -m uvicorn novel_writer_api:app --host 172.17.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
