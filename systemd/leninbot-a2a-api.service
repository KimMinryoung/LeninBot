[Unit]
Description=LeninBot A2A API (FastAPI + Uvicorn)
After=network.target leninbot-neo4j.service
Requires=leninbot-neo4j.service

[Service]
User=grass
WorkingDirectory=/home/grass/leninbot
EnvironmentFile=/home/grass/leninbot/.env
ExecStart=/home/grass/leninbot/venv/bin/python -m uvicorn a2a_api:app --host 172.17.0.1 --port 8003
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
