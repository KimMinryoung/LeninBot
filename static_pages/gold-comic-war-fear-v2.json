  "html_body": "<article class=\"comic-page\">\n  <style>\n    .comic-page { max-width: 960px; margin: 0 auto; padding: 8px 0 40px; color: #2d3436; }\n    .comic-panel { margin: 0 0 20px; }\n    .comic-panel:last-child { margin-bottom: 0; }\n    .comic-panel-svg { width: 100%; height: auto; display: block; }\n    .comic-panel-box { fill: #fffdf5; stroke: #2d3436; stroke-width: 3; }\n    .comic-balloon rect { fill: #ffffff; stroke: #2d3436; stroke-width: 3; }\n    .comic-balloon path { fill: #ffffff; stroke: #2d3436; stroke-width: 3; stroke-linejoin: round; }\n    .comic-speech { font-family: \"Helvetica Neue\", \"Noto Sans KR\", system-ui, sans-serif; font-size: 26px; font-weight: 800; fill: #2d3436; letter-spacing: 0.02em; }\n  </style>\n  <figure class=\"comic-panel\" aria-label=\"Panel 1\">\n    <svg class=\"comic-panel-svg\" viewBox=\"0 0 960 320\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\">\n      <rect x=\"3\" y=\"3\" width=\"954\" height=\"314\" rx=\"22\" class=\"comic-panel-box\" />\n      <g class=\"comic-scene\"><g transform=\"translate(480, 30) scale(2.2)\"><line x1=\"38\" y1=\"10\" x2=\"32\" y2=\"22\" stroke=\"#2d3436\" stroke-width=\"2.5\" stroke-linecap=\"round\"/><line x1=\"58\" y1=\"10\" x2=\"64\" y2=\"22\" stroke=\"#2d3436\" stroke-width=\"2.5\" stroke-linecap=\"round\"/><circle cx=\"38\" cy=\"10\" r=\"2\" fill=\"#2d3436\"/><circle cx=\"58\" cy=\"10\" r=\"2\" fill=\"#2d3436\"/><rect x=\"12\" y=\"22\" width=\"76\" height=\"56\" rx=\"6\" fill=\"#636e72\" stroke=\"#2d3436\" stroke-width=\"2.5\"/><rect x=\"18\" y=\"28\" width=\"64\" height=\"44\" rx=\"2\" fill=\"#b0d8ef\" stroke=\"#2d3436\" stroke-width=\"1.5\"/><text x=\"50\" y=\"46\" font-family=\"system-ui, sans-serif\" font-size=\"10\" font-weight=\"700\" fill=\"#2d3436\" text-anchor=\"middle\">휴전 기대</text><line x1=\"24\" y1=\"52\" x2=\"76\" y2=\"52\" stroke=\"#2d3436\" stroke-width=\"1\"/><line x1=\"24\" y1=\"56\" x2=\"60\" y2=\"56\" stroke=\"#2d3436\" stroke-width=\"1\"/><rect x=\"18\" y=\"